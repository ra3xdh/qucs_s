<Paintings>
  <Rectangle 60 20 230 190 #000000 0 1 #c0c0c0 1 0>
  <Text 70 140 14 #00007f 90 "bias stabilisation">
  <Arrow 390 200 -20 -60 20 8 #ff0000 3 1 0>
  <Text 770 -30 12 #000000 0 "Circuits of this kind are used to stabilize the bias of RF\ntransistors. But sometimes they tend to LF oscillations.\n\n\nThis schematic shows how to determine the degree of stability\nby simulating magnitude and phase margin of the loop gain.\n\n\nResult: As a rule of thumb, it should be  C2 >> C1">
  <Text 360 200 12 #ff0000 0 "for measuring\nthe loop stability">
</Paintings>
